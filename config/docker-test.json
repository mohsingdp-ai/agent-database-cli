      "url": "mysql://test:test@127.0.0.1:3306/app",
      "readonly": false,
      "blacklist": ["drop", "truncate"],
      "keepAliveSeconds": 180
    },
    "local-postgres": {
      "type": "postgres",
      "url": "postgres://test:test@127.0.0.1:5432/app",
      "readonly": false,
      "blacklist": ["drop", "truncate"],
      "keepAliveSeconds": 180
    },
    "local-redis": {
