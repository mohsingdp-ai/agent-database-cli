{
  "name": "@sleepinsummer/database-cli",
  "version": "0.1.0",
  "description": "统一数据库命令行工具，支持只读、黑名单和本地连接守护进程。",
  "type": "module",
  "bin": {
    "database-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "DATABASE_CLI_CONFIG=config/docker-test.json vitest run tests/integration --exclude tests/integration/oracle.test.ts",
    "test:integration:oracle": "DATABASE_CLI_CONFIG=config/docker-test.json vitest run tests/integration/oracle.test.ts"
  },
  "files": [
    "dist",
    "README.md",
    "README_EN.md",
    "AI_INSTALL.md",
    "SKILL.md",
    "LICENSE",
    "config/docker-test.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "mongodb": "^6.20.0",
    "mysql2": "^3.15.3",
    "oracledb": "^6.10.0",
    "pg": "^8.16.3",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
