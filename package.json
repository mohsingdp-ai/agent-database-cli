{
  "name": "@mejazbese21/agent-database-cli",
  "version": "1.1.0",
  "description": "Unified database CLI with read-only mode and a command blocklist; each command opens a direct connection.",
  "type": "module",
  "bin": {
    "agent-database-cli": "bin/agent-database-cli.js",
    "agent-database-cli-mcp": "bin/mcp.js",
    "db-cli": "bin/agent-database-cli.js",
    "db-cli-mcp": "bin/mcp.js"
  },
  "scripts": {
    "build": "cargo build --release --bin agent-database-cli",
    "build:rust": "cargo build --release --bin agent-database-cli",
    "dev": "cargo run --bin agent-database-cli --",
    "dev:rust": "cargo run --bin agent-database-cli --",
    "test": "cargo test",
    "check": "cargo check --bin agent-database-cli",
    "postinstall": "node bin/postinstall.js"
  },
  "files": [
    "bin",
    "README.md",
    "AI_INSTALL.md",
    "SKILL.md",
    "skills",
    "LICENSE",
    "config/docker-test.json"
  ],
  "optionalDependencies": {
    "@mejazbese21/db-cli-darwin-arm64": "1.1.0",
    "@mejazbese21/db-cli-darwin-x64": "1.1.0",
    "@mejazbese21/db-cli-linux-arm64": "1.1.0",
    "@mejazbese21/db-cli-linux-x64": "1.1.0",
    "@mejazbese21/db-cli-win32-x64": "1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mohsingdp-ai/agent-database-cli"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
